model TipSuggestion {
  id       String        @id @default(cuid())
  content  String
  category TipCategory   @default(NO_CATEGORY)
  days     ExerciseDay[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model CueMedia {
  id        String    @id @default(cuid())
  cueId     String
  url       String
  mediaType MediaType
  order     Int       @default(0)

  cue ExerciseCue @relation(fields: [cueId], references: [id], onDelete: Cascade)

  @@index([cueId])
}
