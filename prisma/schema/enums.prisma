enum ImageRole {
  THUMBNAIL // static preview
  DEMONSTRATION // full technique image
  VIDEO // mp4 demonstration
  MUSCLE_MAP // activation diagram
  DIAGRAM // anatomical illustration
  HIGHLIGHT // activated muscle highlight
  AVATAR // user profile picture
  PROGRESS_PHOTO // body progress
}

enum MediaType {
  IMAGE
  GIF
  VIDEO
}

enum PrioritySide {
  LEFT
  RIGHT
  BOTH
}

enum MuscleSize {
  SMALL // biceps, calves, forearms
  MEDIUM // shoulders, triceps, hamstrings
  LARGE // back, chest, quadriceps, glutes
}

enum MuscleRole {
  PRIMARY
  SECONDARY
  STABILIZER
}

enum MovementRole {
  PRIMARY
  ASSISTS
}

enum MovementPlane {
  SAGITTAL
  FRONTAL
  TRANSVERSE
}

enum MuscleGroup {
  PUSH
  PULL
  LEGS
  UPPER_BODY
  ARMS
  BACK
  CHEST
  DELTS
  MIX
}

enum Split {
  NO_SPLIT
  PUSH_PULL_LEGS
  BRO_SPLIT
  UPPER_LOWER
  SEVEN_DAYS
  OTHER
}

enum SessionStatus {
  NO_STATUS
  PLANNED
  ACTIVE
  COMPLETED
  SKIPPED
  PARTIAL
}

enum TipCategory {
  NO_CATEGORY
  NUTRITION
  SUPPLEMENT
  TECHNIQUE
  HEALTH
}

enum MeasurementContext {
  STANDALONE // periodic weigh-in — not tied to a session
  PRE_WORKOUT // measured before session — baseline
  POST_WORKOUT // measured after session — pump, hydration effect
  MORNING // fasted, first thing — most accurate for trends
  EVENING // end of day — highest body weight typically
}

enum PRType {
  ESTIMATED_1RM
  HEAVIEST_SET
  MAX_REPS
  MAX_VOLUME_SESSION
}

enum SetType {
  WORKING // standard set
  WARMUP // warmup — exclude from volume
  DROP // weight dropped from previous set
  BACKOFF // planned lighter set after heavy sets
  FAILURE // taken to failure
}

enum ROM {
  FULL
  LOWER
  UPPER
}

enum Sex {
  MALE
  FEMALE
}

enum ClashSeverity {
  NO_CLASH
  TINY
  MEDIUM
  HIGH
  CRITICAL
  AVOID
  SPACE
}

enum WeeklyFrequency {
  STOPPED
  ONCE_WEEKLY
  TWICE_WEEKLY
  THREE_TIMES_WEEKLY
  EVERY_OTHER_DAY
  DAILY
  TWICE_DAILY
  THREE_TIMES_DAILY
  WORKOUT_DAYS_ONLY
}

enum DayTiming {
  FASTED_WAKE
  MEAL_1
  MEAL_2
  MEAL_3
  PRE_WORKOUT
  INTRA_WORKOUT
  POST_WORKOUT
  PRE_SLEEP
}

enum MealTiming {
  BEGGINNING
  MIDDLE
  END
}

enum MealType {
  FASTING
  PROTEIN
  CARBS
  FATS
  FIBERS
  SUGAR
}

enum CofactorType {
  ENHANCES_ABSORPTION // e.g. Vitamin D + K2, fat-soluble + fat
  ENHANCES_EFFICACY // e.g. Creatine + carbs (insulin-mediated uptake)
  REQUIRED_TOGETHER // e.g. Calcium + Magnesium balance
  SYNERGISTIC_EFFECT // combined effect greater than sum of parts
}

enum MedicalConditionCategory {
  CARDIOVASCULAR
  RENAL
  METABOLIC
  RESPIRATORY
  ENDOCRINE
  NEUROLOGICAL
  GASTROINTESTINAL
  MUSCULOSKELETAL
  HEMATOLOGIC
  PSYCHIATRIC
  REPRODUCTIVE
  OTHER
}

enum TrainingGoal {
  HYPERTROPHY
  STRENGTH
  FAT_LOSS
  ENDURANCE
  RECOMPOSITION
  MAINTENANCE
}

enum LeverCategory {
  PERFORMANCE
  RECOVERY
  COMPOSITION
  HORMONAL
  COGNITIVE
  STRUCTURAL
  NUTRITIONAL_GAP
}

enum HormonalEffectDirection {
  SUPPORTS // evidence the supplement raises/supports this hormone
  SUPPRESSES // evidence the supplement lowers/inhibits this hormone
  MODULATES // affects sensitivity/receptor activity rather than level
}

enum EvidenceTier {
  STRONG // multiple high-quality human studies, consistent findings
  MODERATE // some good human studies, smaller or less consistent
  LIMITED // weak/preliminary human evidence, mostly mechanistic
  EMERGING // very new research area, not yet replicated
}

enum RiskTolerance {
  CONSERVATIVE
  STANDARD
  AGGRESSIVE
}

enum DietaryPattern {
  OMNIVORE
  VEGETARIAN
  VEGAN
}

enum SensitivityLevel {
  INTOLERANT // avoid entirely — adverse reaction even at low dose
  SENSITIVE // tolerate at reduced dose only
  NORMAL // standard dosing fine
  RESISTANT // requires higher than typical dose for effect
}

enum FoodInteractionType {
  ENHANCES_ABSORPTION // CoQ10 + fatty meal
  REQUIRES_PRESENCE // fat-soluble vitamins need fat present at all
  REDUCES_ABSORPTION // Zinc + dairy/calcium
  REQUIRES_AVOIDANCE // some supplements need empty stomach
  DELAYS_ABSORPTION // fiber slowing uptake
}

enum OccupationalActivity {
  SEDENTARY // desk job, mostly sitting
  STANDING // mostly on feet, low exertion
  ACTIVE // physically demanding job
  MIXED
}

enum PreferenceDirection {
  MUST_INCLUDE // user explicitly wants this, force into final list
  EXCLUDE // user explicitly refuses this, remove regardless of rank
}

enum ConsentType {
  TERMS_OF_SERVICE
  HEALTH_DATA_PROCESSING
  MARKETING
  AI_DATA_USAGE
}

enum ErasureScope {
  HEALTH_DATA_ONLY
  FULL_ACCOUNT
}

enum DoseStatus {
  PENDING
  TAKEN
  SKIPPED
  MISSED
}

enum QuantityUnit {
  GRAMS
  CAPSULES
  MILLILITERS
}

enum CueType {
  SETUP
  EXECUTION
  MIND_MUSCLE
  COMMON_MISTAKE
}
