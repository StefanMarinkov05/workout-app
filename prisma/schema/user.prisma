model User {
  id            String  @id @default(cuid())
  name          String
  nickname      String?
  age           Float?
  sex           Sex
  weight        Float?
  targetWeight  Float?
  bodyFat       Float?
  motivation    String?
  profilePicUrl String?
  scheduleId String?

  photos       Image[]
  schedules    Schedule?
  userStats    UserStats?
  equipments   UserEquipment[]
  bodyMeasures BodyMeasurement[]

  progressSnapshots ProgressSnapshot[]
  personalRecords PersonalRecord[]
  exerciseTypeFrequencies ExerciseTypeFrequency[]
  progressionEvents ProgressionEvent[]

  supplements  UserSupplement[]
  nutritionTarget   NutritionTarget?
  medicalConditions UserMedicalCondition[]
  userMedications UserMedication[]
  
  createdAt DateTime  @default(now())
  updatedAt DateTime?
  deletedAt DateTime?
}

model NutritionTarget {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  proteinMinG    Float?
  proteinMaxG    Float?
  carbsMinG      Float?
  carbsMaxG      Float?
  fatMinG        Float?
  fatMaxG        Float?
  kcalMin        Float?
  kcalMax        Float?
  waterTrainingL Float?
  waterRestL     Float?
  fructoseMaxG   Float?
  saltMaxG       Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}
