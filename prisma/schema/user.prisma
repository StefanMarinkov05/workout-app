model User {
  id            String   @id @default(cuid())
  name          String
  nickname      String?
  age           Float?
  sex           Sex
  isPregnant    Boolean?
  isLactating   Boolean?
  targetWeight  Float?
  profilePicUrl String?
  scheduleId    String?

  primaryGoal                 TrainingGoal?
  secondaryGoal               TrainingGoal?
  riskTolerance               RiskTolerance?
  dietaryPattern              DietaryPattern?       @default(OMNIVORE)
  generalStimulantSensitivity SensitivityLevel?     @default(NORMAL)
  occupationalActivity        OccupationalActivity?

  photos       Image[]
  schedules    Schedule?
  userStats    UserStats?
  equipments   UserEquipment[]
  bodyMeasures BodyMeasurement[]

  progressSnapshots       ProgressSnapshot[]
  personalRecords         PersonalRecord[]
  exerciseTypeFrequencies ExerciseTypeFrequency[]
  progressionEvents       ProgressionEvent[]

  nutritionTarget NutritionTarget?

  supplements                 UserSupplement[]
  medicalConditions           UserMedicalCondition[]
  userMedications             UserMedication[]
  userAllergies               UserAllergy[]
  userSupplementSensitivities UserSupplementSensitivity[]
  userSupplementPreferences   UserSupplementPreference[]

  consents            UserConsent[]
  dataErasureRequests DataErasureRequest[]
  aiusageLogs         AIUsageLog[]

  createdAt DateTime  @default(now())
  updatedAt DateTime?
  deletedAt DateTime?
}

model NutritionTarget {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  proteinMinG    Float?
  proteinMaxG    Float?
  carbsMinG      Float?
  carbsMaxG      Float?
  fatMinG        Float?
  fatMaxG        Float?
  kcalMin        Float?
  kcalMax        Float?
  waterTrainingL Float?
  waterRestL     Float?
  fructoseMaxG   Float?
  saltMaxG       Float?

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model UserSupplement {
  id               String           @id @default(cuid())
  supplementTypeId Int
  userId           String
  dailyDose        Float?
  dailyCapsules    Int?
  weeklyFrequency  WeeklyFrequency?

  quantity  Float?      @default(0)
  dayTiming DayTiming[]

  supplementDoses          SupplementDose[]
  supplementProtocolPhases SupplementProtocolPhase[]

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id])
  user           User           @relation(fields: [userId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@index([supplementTypeId, userId])
}

model UserMedicalCondition {
  id                 String    @id @default(cuid())
  userId             String
  medicalConditionId Int
  diagnosedDate      DateTime?
  severity           String?

  user             User             @relation(fields: [userId], references: [id])
  medicalCondition MedicalCondition @relation(fields: [medicalConditionId], references: [id])

  createdAt DateTime @default(now())
  // hard delete only

  @@unique([userId, medicalConditionId])
  @@index([medicalConditionId])
}

model UserMedication {
  id           String @id @default(cuid())
  userId       String
  medicationId Int
  dosage       Float?

  dayTiming       DayTiming[]
  weeklyFrequency WeeklyFrequency

  user       User       @relation(fields: [userId], references: [id])
  medication Medication @relation(fields: [medicationId], references: [id])

  createdAt DateTime @default(now())
  // hard delete only

  @@unique([userId, medicationId])
  @@index([medicationId])
}

model UserAllergy {
  id         String @id @default(cuid())
  userId     String
  allergenId Int

  user     User     @relation(fields: [userId], references: [id])
  allergen Allergen @relation(fields: [allergenId], references: [id])

  createdAt DateTime @default(now())
  // hard delete only

  @@unique([userId, allergenId])
}

model UserSupplementSensitivity {
  id               String           @id @default(cuid())
  userId           String
  supplementTypeId Int
  level            SensitivityLevel
  notes            String?

  user           User           @relation(fields: [userId], references: [id])
  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, supplementTypeId])
}

model UserSupplementPreference {
  id               String              @id @default(cuid())
  userId           String
  supplementTypeId Int
  direction        PreferenceDirection
  reason           String? // optional — "tried before, didn't like it",
  // "ethical/dietary reasons", "previous bad reaction"

  user           User           @relation(fields: [userId], references: [id])
  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id])

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  @@unique([userId, supplementTypeId])
}
