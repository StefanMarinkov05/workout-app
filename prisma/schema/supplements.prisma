// the supplement itself — reference data, shared definition
model SupplementType {
  id              Int      @id @default(autoincrement())
  name            String   @unique
  measurementUnit String // "g", "mg", "mcg", "IU"
  description     String
  aliases         String[] // Vit. D3 == D3 == Cholecalciferol = Vitamin d...

  doseRanges                  SupplementDoseRange[]
  supplementCoFactorsA        SupplementCoFactor[]              @relation("CofactorA")
  supplementCoFactorsB        SupplementCoFactor[]              @relation("CofactorB")
  clashesA                    SupplementClash[]                 @relation("ClashA")
  clashesB                    SupplementClash[]                 @relation("ClashB")
  userSupplements             UserSupplement[]
  medicalClashes              SupplementMedicalConditionClash[]
  medicationClashes           SupplementMedicationClash[]
  supplementAllergens         SupplementAllergen[]
  supplementHormonalEffects   SupplementHormonalEffect[]
  userSupplementSensitivities UserSupplementSensitivity[]
  supplementFoodInteractions  SupplementFoodInteraction[]
  supplementUsageTips         SupplementUsageTip[]
  userSupplementPreferences   UserSupplementPreference[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?
}

model SupplementDoseRange {
  id                 String   @id @default(cuid())
  supplementTypeId   Int
  sex                Sex?
  minAgeYears        Int?
  maxAgeYears        Int?
  medicalConditionId Int? // one condition per row — multiple rows for multiple conditions
  isPregnant         Boolean? // null = cannot get pregnant
  lowerLimit         Float?
  upperLimit         Float?
  toleranceLimit     Float?
  sourceUrl          String
  verifiedAt         DateTime
  verifiedBy         String?

  supplementType   SupplementType    @relation(fields: [supplementTypeId], references: [id])
  medicalCondition MedicalCondition? @relation(fields: [medicalConditionId], references: [id])

  @@index([supplementTypeId, medicalConditionId])
}

// ===== SUPPLEMENT PAIRING =====
model SupplementCoFactor {
  supplementAId Int // always store the SMALLER id here
  supplementBId Int // always store the LARGER id here
  type          CofactorType
  reason        String
  sourceUrl     String
  verifiedAt    DateTime
  verifiedBy    String?

  supplementA SupplementType @relation("CofactorA", fields: [supplementAId], references: [id], onDelete: Cascade)
  supplementB SupplementType @relation("CofactorB", fields: [supplementBId], references: [id], onDelete: Cascade)

  @@id([supplementAId, supplementBId])
  @@index([supplementBId])
}

model SupplementClash {
  id                 String        @id @default(cuid())
  supplementAId      Int
  supplementBId      Int
  medicalConditionId Int? // null = always applies, or condition-specific
  severity           ClashSeverity
  evidenceTier       EvidenceTier
  sourceUrl          String
  verifiedAt         DateTime
  verifiedBy         String?
  reason             String
  minSpacingHours    Int? // null = no specific spacing helps

  supplementA      SupplementType    @relation("ClashA", fields: [supplementAId], references: [id], onDelete: Cascade)
  supplementB      SupplementType    @relation("ClashB", fields: [supplementBId], references: [id], onDelete: Cascade)
  medicalCondition MedicalCondition? @relation(fields: [medicalConditionId], references: [id])

  @@unique([supplementAId, supplementBId, medicalConditionId])
  @@index([supplementBId])
}

// ===== SUPPLEMENT + MED. CONDITION =====
model MedicalCondition {
  id          Int                       @id @default(autoincrement())
  name        String                    @unique
  description String?
  category    MedicalConditionCategory?
  aliases     String[] // ["renal disease", "CKD"] — intake matching

  doseRanges        SupplementDoseRange[]
  clashes           SupplementMedicalConditionClash[]
  supplementClashes SupplementClash[]
  userConditions    UserMedicalCondition[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model SupplementMedicalConditionClash {
  id                 String        @id @default(cuid())
  supplementTypeId   Int
  medicalConditionId Int
  severity           ClashSeverity
  evidenceTier       EvidenceTier
  reason             String
  sourceUrl          String
  verifiedAt         DateTime
  verifiedBy         String?

  supplementType   SupplementType   @relation(fields: [supplementTypeId], references: [id], onDelete: Cascade)
  medicalCondition MedicalCondition @relation(fields: [medicalConditionId], references: [id], onDelete: Cascade)

  @@unique([supplementTypeId, medicalConditionId])
  @@index([medicalConditionId])
}

// ===== SUPPLEMENT + MEDICATION =====

// prescribed drugs antibiotics etc...
model Medication {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  aliases     String[]

  supplementMedicationClashes SupplementMedicationClash[]
  userMedications             UserMedication[]
}

model SupplementMedicationClash {
  id               String        @id @default(cuid())
  supplementTypeId Int
  medicationId     Int
  severity         ClashSeverity
  evidenceTier     EvidenceTier
  reason           String
  sourceUrl        String
  verifiedAt       DateTime
  verifiedBy       String?

  // optional — null means the clash applies regardless of amount
  // (the common case). when set, the clash only activates if the
  // resolved dose meets or exceeds this threshold
  onlyAboveDose   Float?
  minSpacingHours Float?

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id], onDelete: Cascade)
  medication     Medication     @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@unique([supplementTypeId, medicationId])
  @@index([medicationId])
}

// ===== SUPPLEMENT + ALLERGIES =====

model Allergen {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String?
  aliases     String[]

  supplementAllergens SupplementAllergen[]
  userAllergies       UserAllergy[]
}

model SupplementAllergen {
  supplementTypeId Int
  allergenId       Int
  severity         ClashSeverity @default(AVOID)
  evidenceTier     EvidenceTier
  reason           String
  sourceUrl        String
  verifiedAt       DateTime
  verifiedBy       String?

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id], onDelete: Cascade)
  allergen       Allergen       @relation(fields: [allergenId], references: [id], onDelete: Cascade)

  @@id([supplementTypeId, allergenId])
}

// ===== SUPPLEMENT + HORMONE =====

model Hormone {
  id          Int      @id @default(autoincrement())
  name        String   @unique
  description String
  aliases     String[]

  supplementHormonalEffects SupplementHormonalEffect[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model SupplementHormonalEffect {
  id               String @id @default(cuid())
  supplementTypeId Int
  hormoneId        Int

  direction    HormonalEffectDirection
  evidenceTier EvidenceTier
  reason       String?
  sourceUrl    String
  verifiedAt   DateTime
  verifiedBy   String?

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id])
  hormone        Hormone        @relation(fields: [hormoneId], references: [id])

  @@unique([supplementTypeId, hormoneId])
  @@index([hormoneId])
}

// ====== SUPPLEMENT + MEAL =====

model Food {
  id          Int      @id @default(autoincrement())
  name        String   @unique // "Dairy", "Fatty Meal", "Coffee", "Fiber-rich meal"
  description String?
  aliases     String[]

  interactions SupplementFoodInteraction[]

  createdAt DateTime  @default(now())
  deletedAt DateTime?
}

model SupplementFoodInteraction {
  id               String              @id @default(cuid())
  supplementTypeId Int
  mealType         MealType? // generic macronutrient-based requirement
  foodId           Int? // specific food, when the interaction is
  // food-specific rather than macronutrient-general
  mealTiming       MealTiming? // beginning/middle/end of the meal, if it matters
  type             FoodInteractionType
  reason           String
  minSpacingHours  Int?
  sourceUrl        String
  verifiedAt       DateTime
  verifiedBy       String?

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id], onDelete: Cascade)
  food           Food?          @relation(fields: [foodId], references: [id], onDelete: Cascade)

  @@index([foodId])
  @@index([supplementTypeId, mealType])
}

model SupplementUsageTip {
  id               String      @id @default(cuid())
  supplementTypeId Int
  tip              String // "Take with a meal to improve survival
  // through stomach acid"
  dayTiming        DayTiming?
  mealTiming       MealTiming?
  sourceUrl        String? // optional here — general practice
  // guidance is held to a lighter sourcing
  // bar than a clash/safety claim
  verifiedAt       DateTime?

  supplementType SupplementType @relation(fields: [supplementTypeId], references: [id], onDelete: Cascade)

  @@index([supplementTypeId])
}

model SupplementDose {
  id               String     @id @default(cuid())
  userSupplementId String
  scheduledDate    DateTime
  dayTiming        DayTiming
  status           DoseStatus @default(PENDING)
  takenAt          DateTime?
  skipReason       String?

  userSupplement UserSupplement @relation(fields: [userSupplementId], references: [id], onDelete: Cascade)

  createdAt DateTime  @default(now())
  deletedAt DateTime?

  @@index([userSupplementId, scheduledDate])
  @@index([scheduledDate])
}

model SupplementProtocolPhase {
  id               String          @id @default(cuid())
  userSupplementId String
  phaseOrder       Int // 1, 2, 3 — sequence
  durationDays     Int
  dailyDose        Float
  weeklyFrequency  WeeklyFrequency

  userSupplement UserSupplement @relation(fields: [userSupplementId], references: [id], onDelete: Cascade)

  @@index([userSupplementId, phaseOrder])
}
